{
  "name": "@ai-dev/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-dev/shared": "file:../../packages/shared",
    "@vitejs/plugin-react": "^5.2.0",
    "electron-updater": "^6.6.2",
    "i18next": "^23.12.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^5.5.4",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.elevium.aideveloperdesktop",
    "productName": "AI Developer Desktop",
    "directories": {
      "output": "dist-installers"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
